<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_saleorder_document_l10n_br_sale" inherit_id="sale.report_saleorder_document">
        <!-- Substituição do campo usado para Impostos no Brasil -->
        <xpath expr="//tbody[hasclass('sale_tbody')]//t[@t-as='line']/tr/t[@t-if='not line.display_type']/td[@name='td_taxes']" position="replace">
            <td name="td_taxes" class="text-right">
                <span t-esc="', '.join(map(lambda x: (x.name), line.fiscal_tax_ids))"/>
            </td>
        </xpath>
        <!-- Inclusão de outros Totais usados no Brasil -->
        <!-- Como não há um Name na chave referente ao amount_untaxed so conseguir ordenar de
             acordo com a tela fazendo esses dois replaces abaixo em seguida incluindo novamente -->
        <xpath expr="//div[@name='total']/div/table/tr/td[@name='td_amount_untaxed_label']" position="replace">
        </xpath>
        <xpath expr="//div[@name='total']/div/table/tr/td[@name='td_amount_untaxed']" position="replace">
        </xpath>
        <xpath expr="//div[@name='total']/div/table/t[@t-as='amount_by_group']" position="before">
            <tr class="border-black o_subtotal" style="">
                <td name="td_amount_gross_label"><strong>Montante Bruto</strong></td>
                <td name="td_amount_untaxed" class="text-right">
                    <span t-field="doc.amount_gross"/>
                </td>
            </tr>
            <tr style="">
                <td name="td_amount_untaxed_label"><strong>Valor sem Impostos</strong></td>
                <td name="td_amount_untaxed" class="text-right">
                    <span t-field="doc.amount_untaxed"/>
                </td>
            </tr>
            <tr style="">
                <td name="td_amount_freight_label"><strong>Frete</strong></td>
                <td name="td_amount_freight" class="text-right">
                    <span t-field="doc.amount_freight"/>
                </td>
            </tr>
            <tr style="">
                <td name="td_amount_insurance_label"><strong>Seguro</strong></td>
                <td name="td_amount_insurance" class="text-right">
                    <span t-field="doc.amount_insurance"/>
                </td>
            </tr>
            <tr style="">
                <td name="td_amount_costs_label"><strong>Outros Custos</strong></td>
                <td name="td_amount_costs" class="text-right">
                    <span t-field="doc.amount_costs"/>
                </td>
            </tr>
            <tr style="">
                <td name="td_amount_tax_label"><strong>Impostos</strong></td>
                <td name="td_amount_tax" class="text-right">
                    <span t-field="doc.amount_tax"/>
                </td>
            </tr>

        </xpath>
    </template>

</odoo>
